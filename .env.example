# In local dev, requests to /api are proxied by Vite (see vite.config.ts)
# to the real backend, which avoids CORS issues in the browser.
VITE_API_BASE_URL=/api/v1

# In production, point this directly at the backend
# (it must allow CORS from this app's origin), e.g.:
# VITE_API_BASE_URL=http://178.212.12.22:8000/api/v1
